---
/*
  Replace YOUR_FORMSPREE_ID with your actual Formspree form ID.
  Get one free at https://formspree.io
*/
const formAction = "https://formspree.io/f/xgolpwpn";
---

<section
  id="contact"
  class="px-5 py-8 md:py-12 bg-dark text-white texture-grain"
>
  <div class="mx-auto max-w-3xl relative z-10">
    <h2
      class="reveal font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight mb-4 text-center text-white"
    >
      Let's Work Together
    </h2>
    <p class="reveal text-center text-white/70 text-lg mb-14 font-body">
      Remote, On-site and Travel Ready
    </p>

    <form
      action={formAction}
      method="POST"
      class="reveal space-y-5"
      id="contact-form"
    >
      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label
            for="name"
            class="block text-sm font-display font-medium text-white/80 mb-2"
            >Name</label
          >
          <input
            type="text"
            name="name"
            id="name"
            required
            class="form-input w-full bg-white/15 border-2 border-white/25 rounded-xl px-4 py-3 text-white placeholder:text-white/40 font-body"
            placeholder="Your name"
          />
        </div>
        <div>
          <label
            for="email"
            class="block text-sm font-display font-medium text-white/80 mb-2"
            >Email</label
          >
          <input
            type="email"
            name="email"
            id="email"
            required
            class="form-input w-full bg-white/15 border-2 border-white/25 rounded-xl px-4 py-3 text-white placeholder:text-white/40 font-body"
            placeholder="you@email.com"
          />
        </div>
      </div>
      <div>
        <label
          for="message"
          class="block text-sm font-display font-medium text-white/80 mb-2"
          >Message</label
        >
        <textarea
          name="message"
          id="message"
          rows="5"
          required
          class="form-input w-full bg-white/15 border-2 border-white/25 rounded-xl px-4 py-3 text-white placeholder:text-white/40 font-body resize-none"
          placeholder="Send some details, let's talk possibilities!"
        ></textarea>
      </div>
      <div class="text-center pt-2">
        <button
          type="submit"
          class="inline-flex items-center gap-2 bg-cream text-dark px-8 py-3.5 rounded-full font-display font-medium text-base hover:bg-yellow hover:text-dark transition-colors duration-300"
        >
          Send Note
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M3 8h10M13 8l-4 4M13 8l-4-4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </form>

    <div class="hidden text-center py-12" id="form-success">
      <p class="font-display font-bold text-2xl mb-2 text-white">
        Message sent!
      </p>
      <p class="text-white/60 font-body">I'll be in touch soon.</p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("form-success")!;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    btn.textContent = "Sending...";
    btn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        form.classList.add("hidden");
        success.classList.remove("hidden");
      } else {
        btn.textContent = "Something went wrong — try again";
        btn.disabled = false;
      }
    } catch {
      btn.textContent = "Something went wrong — try again";
      btn.disabled = false;
    }
  });
</script>
