---
const year = new Date().getFullYear();
const contactEmail = "kennyjohnsemail@gmail.com";
---

<footer class="bg-dark text-cream px-5 py-5">
  <div
    class="mx-auto max-w-6xl flex flex-col sm:flex-row items-center justify-between gap-6"
  >
    <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-5">
      <a
        href="/credits"
        class="text-cream/50 hover:text-coral text-sm font-body transition-colors"
      >
        Credits
      </a>
      <div class="flex items-center gap-5">
      {/* Email */}
      <a
        href={`mailto:${contactEmail}`}
        class="text-cream hover:text-coral transition-colors"
        aria-label="Email"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
          ></path>
        </svg>
      </a>

      {/* Telegram */}
      <a
        href="https://t.me/KennyJohns_AMPLE"
        target="_blank"
        rel="noopener noreferrer"
        class="text-cream hover:text-coral transition-colors"
        aria-label="Telegram"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
          ></path>
        </svg>
      </a>
      </div>
    </div>

    <p class="text-cream/30 text-sm font-body">
      &copy; {year} Kenny Johns. All rights reserved.
    </p>
  </div>
</footer>
