---
/* Replace VIDEO_ID with your actual YouTube video ID */
const videoId = "WbPaJWlxrMI";
const posterUrl = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
---

<section id="reel" class="px-5 py-8 md:py-12 bg-blue texture-grain">
  <div class="mx-auto max-w-5xl relative z-10">
    <h2 class="reveal font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight mb-10 text-center text-cream">
      See samples in &lt;90 seconds
    </h2>
    <div class="reveal">
      <div
        class="yt-lite"
        data-video-id={videoId}
        style={`background-image: url('${posterUrl}');`}
      >
        <button class="play-btn" aria-label="Play video reel">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 5v14l11-7z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>(".yt-lite").forEach((el) => {
    el.addEventListener("click", function () {
      if (el.classList.contains("activated")) return;
      const id = el.dataset.videoId;
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = "Video reel";
      iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
      iframe.allowFullscreen = true;
      iframe.style.cssText = "position:absolute;inset:0;width:100%;height:100%;border:0;";
      el.classList.add("activated");
      el.innerHTML = "";
      el.appendChild(iframe);
    });
  });
</script>
