---
import { navItems } from "../data/nav";
---

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-black/[0.9] backdrop-blur-[2px] border-b border-white/10"
  id="site-header"
>
  <div class="mx-auto max-w-7xl px-5 py-4 flex items-center justify-between">
    <a
      href="#"
      class="font-display font-bold text-2xl md:text-3xl tracking-tight text-cream hover:text-blue transition-colors"
    >
      KJ
    </a>

    {/* Desktop nav */}
    <nav class="hidden md:flex items-center gap-3" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-pill px-5 py-2 rounded-full border-2 ${item.border} text-sm font-display font-medium text-cream ${item.hoverBg} hover:text-white hover:border-transparent`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    {/* Mobile hamburger */}
    <button
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
      id="menu-toggle"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span
        class="block w-6 h-0.5 bg-cream transition-all duration-300 origin-center"
        id="bar-1"></span>
      <span
        class="block w-6 h-0.5 bg-cream transition-all duration-300"
        id="bar-2"></span>
      <span
        class="block w-6 h-0.5 bg-cream transition-all duration-300 origin-center"
        id="bar-3"></span>
    </button>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")!;
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar-1")!;
  const bar2 = document.getElementById("bar-2")!;
  const bar3 = document.getElementById("bar-3")!;
  const mobileLinks = menu.querySelectorAll(".mobile-nav-link");

  let menuOpen = false;

  function setMenu(open: boolean) {
    menuOpen = open;
    toggle.setAttribute("aria-expanded", String(open));
    menu.classList.toggle("open", open);
    document.documentElement.style.overflow = open ? "hidden" : "";
    document.body.style.overflow = open ? "hidden" : "";

    if (open) {
      bar1.style.transform = "rotate(45deg) translateY(4px)";
      bar2.style.opacity = "0";
      bar3.style.transform = "rotate(-45deg) translateY(-4px)";
    } else {
      bar1.style.transform = "";
      bar2.style.opacity = "";
      bar3.style.transform = "";
    }
  }

  toggle.addEventListener("click", () => setMenu(!menuOpen));
  mobileLinks.forEach((link) =>
    link.addEventListener("click", () => setMenu(false))
  );

  window.addEventListener(
    "scroll",
    () => {
      const y = window.scrollY;
      if (y > 80) {
        header.style.background = "rgba(8, 8, 12, 0.95)";
        header.style.backdropFilter = "blur(2px)";
        header.style.boxShadow = "0 1px 12px rgba(0,0,0,0.35)";
      } else {
        header.style.background = "rgba(0, 0, 0, 0.9)";
        header.style.backdropFilter = "blur(2px)";
        header.style.boxShadow = "0 1px 12px rgba(0,0,0,0.18)";
      }
    },
    { passive: true }
  );
</script>
