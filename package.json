    "@playwright/test": "^1.49.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-astro": "^1.3.0",
    "globals": "^15.12.0",
    "happy-dom": "^15.11.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.0",
    "sharp": "^0.34.5",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.15.0",
    "typescript": "^5.6.0",
